{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bujo",
  "version": "0.0.0",
  "identifier": "app.bujo.journal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "bujo",
        "width": 1000,
        "height": 700,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "A minimal, private, local-first digital bullet journal.",
    "longDescription": "bujo is a minimal, private, local-first digital bullet journal. Your entries live on your device (browser storage inside the webview) with optional cloud sync."
  },
  "plugins": {}
}
